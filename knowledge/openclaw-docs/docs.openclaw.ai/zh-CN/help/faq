<span class="line"><span style="color:#6F42C1;--shiki-dark:#B392F0">sudo</span><span style="color:#2B5581;--shiki-dark:#9DB1C5"> tailscale</span><span style="color:#2B5581;--shiki-dark:#9DB1C5"> up</span></span>
