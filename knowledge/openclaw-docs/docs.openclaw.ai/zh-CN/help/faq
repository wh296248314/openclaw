<span class="line"><span style="color:#2B5581;--shiki-dark:#9DB1C5">  browser</span><span style="color:#212121;--shiki-dark:#BBBBBB">:</span><span style="color:#24292EFF;--shiki-dark:#B392F0"> { </span><span style="color:#2B5581;--shiki-dark:#9DB1C5">headless</span><span style="color:#212121;--shiki-dark:#BBBBBB">:</span><span style="color:#1976D2;--shiki-dark:#79B8FF"> true</span><span style="color:#24292EFF;--shiki-dark:#B392F0"> }</span><span style="color:#212121;--shiki-dark:#BBBBBB">,</span></span>
