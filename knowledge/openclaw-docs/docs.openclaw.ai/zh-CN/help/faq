<span class="line"></span>
<span class="line"><span style="color:#C2C3C5;--shiki-dark:#6B737C"># 清除覆盖（回退到配置 auth.order / 轮换）</span></span>
<span class="line"><span style="color:#6F42C1;--shiki-dark:#B392F0">openclaw</span><span style="color:#2B5581;--shiki-dark:#9DB1C5"> models</span><span style="color:#2B5581;--shiki-dark:#9DB1C5"> auth</span><span style="color:#2B5581;--shiki-dark:#9DB1C5"> order</span><span style="color:#2B5581;--shiki-dark:#9DB1C5"> clear</span><span style="color:#2B5581;--shiki-dark:#9DB1C5"> --provider</span><span style="color:#2B5581;--shiki-dark:#9DB1C5"> anthropic</span></span>
