<span class="line"><span style="color:#2B5581;--shiki-dark:#9DB1C5">  gateway</span><span style="color:#212121;--shiki-dark:#BBBBBB">:</span><span style="color:#24292EFF;--shiki-dark:#B392F0"> {</span></span>
<span class="line"><span style="color:#2B5581;--shiki-dark:#9DB1C5">    mode</span><span style="color:#212121;--shiki-dark:#BBBBBB">:</span><span style="color:#22863A;--shiki-dark:#FFAB70"> &quot;remote&quot;</span><span style="color:#212121;--shiki-dark:#BBBBBB">,</span></span>
<span class="line"><span style="color:#2B5581;--shiki-dark:#9DB1C5">    remote</span><span style="color:#212121;--shiki-dark:#BBBBBB">:</span><span style="color:#24292EFF;--shiki-dark:#B392F0"> {</span></span>
<span class="line"><span style="color:#2B5581;--shiki-dark:#9DB1C5">      url</span><span style="color:#212121;--shiki-dark:#BBBBBB">:</span><span style="color:#22863A;--shiki-dark:#FFAB70"> &quot;ws://gateway.tailnet:18789&quot;</span><span style="color:#212121;--shiki-dark:#BBBBBB">,</span></span>
<span class="line"><span style="color:#2B5581;--shiki-dark:#9DB1C5">      token</span><span style="color:#212121;--shiki-dark:#BBBBBB">:</span><span style="color:#22863A;--shiki-dark:#FFAB70"> &quot;your-token&quot;</span><span style="color:#212121;--shiki-dark:#BBBBBB">,</span></span>
<span class="line"><span style="color:#2B5581;--shiki-dark:#9DB1C5">      password</span><span style="color:#212121;--shiki-dark:#BBBBBB">:</span><span style="color:#22863A;--shiki-dark:#FFAB70"> &quot;your-password&quot;</span><span style="color:#212121;--shiki-dark:#BBBBBB">,</span></span>
