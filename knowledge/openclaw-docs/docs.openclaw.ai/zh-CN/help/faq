<span class="line"><span style="color:#2B5581;--shiki-dark:#9DB1C5">    auth</span><span style="color:#212121;--shiki-dark:#BBBBBB">:</span><span style="color:#24292EFF;--shiki-dark:#B392F0"> {</span></span>
<span class="line"><span style="color:#2B5581;--shiki-dark:#9DB1C5">      mode</span><span style="color:#212121;--shiki-dark:#BBBBBB">:</span><span style="color:#22863A;--shiki-dark:#FFAB70"> &quot;token&quot;</span><span style="color:#212121;--shiki-dark:#BBBBBB">,</span></span>
<span class="line"><span style="color:#2B5581;--shiki-dark:#9DB1C5">      token</span><span style="color:#212121;--shiki-dark:#BBBBBB">:</span><span style="color:#22863A;--shiki-dark:#FFAB70"> &quot;replace-me&quot;</span><span style="color:#212121;--shiki-dark:#BBBBBB">,</span></span>
