<span class="line"><span style="color:#6F42C1;--shiki-dark:#B392F0">set</span><span style="color:#2B5581;--shiki-dark:#9DB1C5"> -euo</span><span style="color:#2B5581;--shiki-dark:#9DB1C5"> pipefail</span></span>
