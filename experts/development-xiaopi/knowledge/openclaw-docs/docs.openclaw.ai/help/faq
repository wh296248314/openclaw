<span class="line"><span style="color:#2B5581;--shiki-dark:#9DB1C5">    banner</span><span style="color:#212121;--shiki-dark:#BBBBBB">:</span><span style="color:#24292EFF;--shiki-dark:#B392F0"> {</span></span>
<span class="line"><span style="color:#2B5581;--shiki-dark:#9DB1C5">      taglineMode</span><span style="color:#212121;--shiki-dark:#BBBBBB">:</span><span style="color:#22863A;--shiki-dark:#FFAB70"> &quot;off&quot;</span><span style="color:#212121;--shiki-dark:#BBBBBB">,</span><span style="color:#C2C3C5;--shiki-dark:#6B737C"> // random | default | off</span></span>
