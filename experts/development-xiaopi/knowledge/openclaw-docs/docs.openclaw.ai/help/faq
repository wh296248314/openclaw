<span class="line"><span style="color:#6F42C1;--shiki-dark:#B392F0">eval</span><span style="color:#22863A;--shiki-dark:#FFAB70"> &quot;$(</span><span style="color:#6F42C1;--shiki-dark:#B392F0">/home/linuxbrew/.linuxbrew/bin/brew</span><span style="color:#2B5581;--shiki-dark:#9DB1C5"> shellenv</span><span style="color:#22863A;--shiki-dark:#FFAB70">)&quot;</span></span>
<span class="line"><span style="color:#6F42C1;--shiki-dark:#B392F0">brew</span><span style="color:#2B5581;--shiki-dark:#9DB1C5"> install</span><span style="color:#D32F2F;--shiki-dark:#F97583"> &lt;</span><span style="color:#2B5581;--shiki-dark:#9DB1C5">formul</span><span style="color:#24292EFF;--shiki-dark:#B392F0">a</span><span style="color:#D32F2F;--shiki-dark:#F97583">&gt;</span></span>
