<span class="line"><span style="color:#2B5581;--shiki-dark:#9DB1C5">      groupPolicy</span><span style="color:#212121;--shiki-dark:#BBBBBB">:</span><span style="color:#22863A;--shiki-dark:#FFAB70"> &quot;allowlist&quot;</span><span style="color:#212121;--shiki-dark:#BBBBBB">,</span></span>
<span class="line"><span style="color:#2B5581;--shiki-dark:#9DB1C5">      groupAllowFrom</span><span style="color:#212121;--shiki-dark:#BBBBBB">:</span><span style="color:#24292EFF;--shiki-dark:#B392F0"> [</span><span style="color:#22863A;--shiki-dark:#FFAB70">&quot;+15551234567&quot;</span><span style="color:#24292EFF;--shiki-dark:#B392F0">]</span><span style="color:#212121;--shiki-dark:#BBBBBB">,</span></span>
<span class="line"><span style="color:#24292EFF;--shiki-dark:#B392F0">    }</span><span style="color:#212121;--shiki-dark:#BBBBBB">,</span></span>
