# ============================================================
# HunyuanOCR 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# ============================================================

# ---- 模型配置 ----
# HuggingFace 模型名称 (国内建议使用镜像)
MODEL_NAME=Tencent/HunyuanOCR

# 模型缓存目录 (容器内)
MODEL_CACHE_DIR=/models

# 推理设备: cpu / cuda
DEVICE=cuda

# ---- 服务配置 ----
# API 端口
OCR_PORT=8000

# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ---- 镜像仓库 (CI/CD使用) ----
# GitHub Container Registry
# REGISTRY=ghcr.io
# REGISTRY_USERNAME=your-github-username

# Docker Hub
# REGISTRY=docker.io
# REGISTRY_USERNAME=your-dockerhub-username
# REGISTRY_PASSWORD=your-dockerhub-token

# ---- 本地配置 ----
# 挂载的图片目录 (相对于 docker-compose.yml)
IMAGE_DIR=./images
